{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build grepx",
      "type": "shell",
      "command": "make",
      "args": ["CFLAGS=-std=c11 -Wall -Wextra -Isrc -g -O0"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
